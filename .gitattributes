# Normalize line endings for cross-platform (Vercel uses Linux)
* text=auto eol=lf

# Explicitly LF for source code and configs
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mov binary
*.svg binary
*.webp binary
*.woff binary
*.woff2 binary
